# ConnectSphere v2 — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

PORT=5000
NODE_ENV=development

# MongoDB Atlas — get free cluster at mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT signing secret — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173

# Cloudinary — get free account at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
